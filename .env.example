COMPANY_NAME="Maison Noyer"
SITE_NAME="Maison Noyer"

# Shopify Storefront API — when set, products, collections, menus, cart and
# checkout all pull from Shopify. Leave unset to run on the local demo catalog.
SHOPIFY_REVALIDATION_SECRET=""
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_STORE_DOMAIN="[your-shopify-store-subdomain].myshopify.com"

# Customer accounts are hosted by Shopify. /account redirects to
# https://<SHOPIFY_STORE_DOMAIN>/account by default. Set this only if you use a
# custom account domain (e.g. the new customer-account URL).
SHOPIFY_ACCOUNT_URL=""

# Judge.me reviews (optional). When set, the PDP renders the Judge.me review
# widget; product star ratings come from the synced `reviews.rating` metafield.
NEXT_PUBLIC_JUDGEME_SHOP_DOMAIN=""
NEXT_PUBLIC_JUDGEME_PUBLIC_TOKEN=""

# Klaviyo email capture (15%-off popup + footer newsletter). Server-side, so
# these are NOT public. Until set, signups succeed in the UI but aren't sent.
KLAVIYO_PRIVATE_API_KEY=""
KLAVIYO_LIST_ID=""
